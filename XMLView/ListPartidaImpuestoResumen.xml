<view>
    <columns>
        <column name="special-account" order="100">
            <widget type="text" fieldname="codcuentaesp"/>
        </column>
        <column name="subaccount" order="110">
            <widget type="text" fieldname="codsubcuenta" />
        </column>
        <column name="description" order="120">
            <widget type="textarea" fieldname="descripcion"/>
        </column>
        <column name="pct-vat" display="right" order="130">
            <widget type="number" decimal="2" fieldname="iva"/>
        </column>
        <column name="pct-surcharge" display="right" order="140">
            <widget type="number" decimal="2" fieldname="recargo"/>
        </column>
        <column name="tax-base" display="right" order="150">
            <widget type="money" fieldname="baseimponible" totals="false">
                <option color="danger">lt:0</option>
            </widget>
        </column>
        <column name="quota" display="right" order="160">
            <widget type="money" fieldname="cuota" totals="false">
                <option color="danger">lt:0</option>
            </widget>
        </column>
    </columns>
</view>
